# ── Stripe ────────────────────────────────────────────────────────────────
# Copy this file to `.env.local` (gitignored) and fill in real values.
# Get keys at https://dashboard.stripe.com/apikeys — start in TEST mode.

# Secret key (server-only). Test keys start with sk_test_, live with sk_live_.
STRIPE_SECRET_KEY=sk_test_xxx

# Webhook signing secret for /api/stripe/webhook.
# Local: run `stripe listen --forward-to localhost:3000/api/stripe/webhook`
# and copy the whsec_... it prints. Prod: create the endpoint in the dashboard.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Absolute origin used to build Checkout success/cancel URLs.
# Local dev: http://localhost:3000 — Prod: https://yourdomain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
